<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <title>BrightnessJustWorks</title>
    <organization>com.brightnessjustworks</organization>

    <!-- Welcome and license pages shown by Installer.app -->
    <welcome    file="welcome.html" mime-type="text/html"/>
    <license    file="license.html" mime-type="text/html"/>

    <!-- Apple Silicon only — prevents Rosetta translation of the installer -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="12.0"/>
        </allowed-os-versions>
    </volume-check>
    <installation-check script="checkArch()"/>
    <script>
    function checkArch() {
        var arch = system.sysctl('hw.machine');
        if (arch && arch.indexOf('arm64') !== -1) { return true; }
        my.result.type = 'Fatal';
        my.result.message = 'BrightnessJustWorks requires an Apple Silicon Mac (M1 or later).';
        my.result.title = 'Incompatible Hardware';
        return false;
    }
    </script>

    <!-- Allowed install locations: system /Applications only -->
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>

    <choices-outline>
        <line choice="com.brightnessjustworks.pkg.app"/>
    </choices-outline>

    <choice id="com.brightnessjustworks.pkg.app"
            title="BrightnessJustWorks"
            description="Installs BrightnessJustWorks into /Applications."
            start_selected="true"
            start_enabled="true"
            start_visible="true">
        <pkg-ref id="com.brightnessjustworks.pkg.app"/>
    </choice>

    <pkg-ref id="com.brightnessjustworks.pkg.app"
             version="0"
             onConclusion="none">component.pkg</pkg-ref>

</installer-gui-script>
